# PostgreSQL 接続設定 (Secrets 管理対象)
DB_HOST=your-db-host
DB_PORT=5432
DB_NAME=opendolphin
DB_USER=opendolphin
DB_PASSWORD=change-me
# ↑ 本番環境では Vault/Secrets Manager から注入されるランダムな資格情報を使用する。未更新のまま適用すると接続拒否または監査指摘対象となるため必ず上書きすること。
DB_SSLMODE=verify-full
# DB_SSLROOTCERT には PEM 形式の CA 証明書パスを指定し、必要に応じて docker-compose でマウントする
DB_SSLROOTCERT=/opt/jboss/ssl/root-ca.pem

# ORCA DB 接続設定 (ORCA 専用の Secrets を優先。未設定の場合は DB_* をフォールバック)
ORCA_DB_HOST=
ORCA_DB_PORT=
ORCA_DB_NAME=
ORCA_DB_USER=
ORCA_DB_PASSWORD=
ORCA_DB_SSLMODE=
ORCA_DB_SSLROOTCERT=
# 監査メタ情報 (任意)
ORCA_DB_SECRET_REF=
ORCA_DB_SECRET_VERSION=

# ORCA API (HTTP) 接続設定
# 未設定の場合は custom.properties の orca.orcaapi.* を利用する
ORCA_API_HOST=
ORCA_API_PORT=
ORCA_API_SCHEME=http
ORCA_API_USER=
ORCA_API_PASSWORD=
# ORCA API ベースURL (例: https://weborca-trial.orca.med.or.jp)
ORCA_BASE_URL=
# ORCA_MODE: weborca / onprem
ORCA_MODE=
# ORCA Cloud などで /api 配下に ORCA API がある場合に指定（例: /api）
ORCA_API_PATH_PREFIX=
# WebORCA を強制指定する場合に true（host が weborca-* の場合は自動判定）
ORCA_API_WEBORCA=
# リトライ設定（必要な場合のみ。0 なら無効）
ORCA_API_RETRY_MAX=0
ORCA_API_RETRY_BACKOFF_MS=200

# 実行環境・安全側デフォルト
# OPENDOLPHIN_ENVIRONMENT は必須運用キー（例: dev / stg / prod）
OPENDOLPHIN_ENVIRONMENT=dev
# タイムゾーンは既定 Asia/Tokyo。未指定でも JST 固定になる。
OPENDOLPHIN_TIMEZONE=Asia/Tokyo

# 定期処理（既定 OFF。必要時のみ明示的に true へ変更）
ORCA_PATIENT_SYNC_ENABLED=false
ORCA_PATIENT_SYNC_INTERVAL_MINUTES=5
ORCA_PATIENT_SYNC_INITIAL_LOOKBACK_DAYS=7
ORCA_PATIENT_SYNC_INCLUDE_TEST_PATIENT=false
ORCA_PATIENT_SYNC_INCLUDE_INSURANCE=false
ORCA_PATIENT_SYNC_FACILITY_ID=
# 未設定時は jboss.server.data.dir 配下へ保存
ORCA_PATIENT_SYNC_STATE_PATH=
MASTER_UPDATE_SCHEDULER_ENABLED=false

# 永続化パス（システムプロパティ必須）
# server-modernized は /tmp / user.home フォールバックを使用しない。
# 起動時に必ず -Djboss.server.data.dir=/var/lib/opendolphin/data を指定すること。

# 2FA AES 鍵 (必須)
FACTOR2_AES_KEY_B64=
# ↑ 32 バイト乱数を Base64 した値を設定。未設定で WildFly を起動すると `IllegalStateException` によりデプロイが中断される。

# カルテ本文真正性シール(HMAC)
# DOCUMENT_INTEGRITY_MODE: off / permissive / enforce（未設定時 permissive）
# mode が off 以外の場合は DOCUMENT_INTEGRITY_HMAC_KEY_B64 と DOCUMENT_INTEGRITY_KEY_ID が必須。
DOCUMENT_INTEGRITY_MODE=permissive
DOCUMENT_INTEGRITY_HMAC_KEY_B64=
DOCUMENT_INTEGRITY_KEY_ID=

# Hibernate 実行時プロファイル
HIBERNATE_SHOW_SQL=false
HIBERNATE_FORMAT_SQL=false
