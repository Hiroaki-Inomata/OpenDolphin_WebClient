# P10-01 本番近似検証環境用サンプル
# 利用時はこのファイルを `server-modernized.validation.env` へコピーして実値へ置換すること。

MODERNIZED_POSTGRES_DB=opendolphin_modern
MODERNIZED_POSTGRES_USER=opendolphin_validation
MODERNIZED_POSTGRES_PASSWORD=replace_me_validation_db_password
MODERNIZED_DB_SSLMODE=require
MODERNIZED_DB_SSLROOTCERT=

MODERNIZED_APP_HTTP_PORT=19080
MODERNIZED_APP_ADMIN_PORT=19995
MODERNIZED_POSTGRES_PORT=55442
MODERNIZED_CUSTOM_PROPERTIES_FILE=./ops/modernized-server/config/custom.properties.validation.sample
MODERNIZED_DB_CONTAINER_NAME=opendolphin-postgres-modernized-validation
MODERNIZED_APP_CONTAINER_NAME=opendolphin-server-modernized-validation
MODERNIZED_MINIO_CONTAINER_NAME=opendolphin-minio-validation

MINIO_API_PORT=19100
MINIO_CONSOLE_PORT=19101
MINIO_ROOT_USER=opendolphin
MINIO_ROOT_PASSWORD=replace_me_validation_minio_password
ATTACHMENT_S3_ENDPOINT=http://minio:9000
ATTACHMENT_S3_REGION=ap-northeast-1
ATTACHMENT_S3_FORCE_PATH_STYLE=true
ATTACHMENT_S3_BASE_PATH=clinics/$${FACILITY_ID}
ATTACHMENT_S3_ACCESS_KEY=replace_me_attachment_access_key
ATTACHMENT_S3_SECRET_KEY=replace_me_attachment_secret_key
ATTACHMENT_S3_BUCKET=opendolphin-attachments-validation

PHR_EXPORT_STORAGE_TYPE=s3
PHR_EXPORT_SIGNING_SECRET=replace_me_phr_export_signing_secret
PHR_EXPORT_S3_ENDPOINT=http://minio:9000
PHR_EXPORT_S3_REGION=ap-northeast-1
PHR_EXPORT_S3_FORCE_PATH_STYLE=true
PHR_EXPORT_S3_PREFIX=facility/{facilityId}/jobs/
PHR_EXPORT_S3_BUCKET=opendolphin-phr-export-validation
PHR_EXPORT_S3_ACCESS_KEY=replace_me_phr_export_access_key
PHR_EXPORT_S3_SECRET_KEY=replace_me_phr_export_secret_key

ORCA_TARGET_ENV=preprod
ORCA_MODE=weborca
ORCA_BASE_URL=https://weborca-trial.orca.med.or.jp
ORCA_API_USER=trial
ORCA_API_PASSWORD=replace_me_orca_password

FACTOR2_AES_KEY_B64=replace_with_base64_32bytes_key
FIDO2_RP_ID=validation.opendolphin.local
FIDO2_RP_NAME=OpenDolphin Validation
FIDO2_ALLOWED_ORIGINS=https://validation.opendolphin.local

OTLP_ENABLED=true
OPENDOLPHIN_DISABLE_OTLP_METRICS=false
OTEL_SDK_DISABLED=false
